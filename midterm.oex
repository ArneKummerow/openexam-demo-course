title: "CS101 midterm exam"
params:
  # These mirror `github.com/ArneKummerow/openexam-demo-library@tag:v1.0:assignments/projectile.oex`'s
  # `params:` block. Until caller-side `<import>` binding lands (see
  # CLAUDE.md §8 carryover 7), the imported body inherits *this* file's
  # scope, so the names must match.
  #
  # The `{default: …}` object-literal form is required today because the
  # spec's `default=…` keyword form trips the JS reserved-word rule —
  # see CLAUDE.md §8 carryover 4.
  mass: "int({default: 12})"
  velocity: "oneOf(3, 5, 7, 9, {default: 7})"
  g: 9.81
# `participants:` and `seed:` are intentionally absent here. The demo
# walkthrough builds this exam via:
#   openexam build midterm.oex --defaults defaults.yaml --participants roster.csv
# The roster + the shared department seed live in those external files
# so this `.oex` is reusable across cohorts.
---

